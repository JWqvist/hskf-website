---
import BaseLayout from '../layouts/BaseLayout.astro';

const faq = [
  { q: 'Firmaarrangementer og events', a: 'Vi tilbyder skydeoplevelser for firmaer, polterabender og grupper. Send en bookingforespørgsel via email.' },
  { q: 'Indmeldelse og kontingent', a: 'Bestyrelsen hjælper med indmeldelse og kan oplyse om aktuelle kontingentpriser.' },
  { q: 'SKV', a: 'Klubbens instruktører vejleder om SKV-ansøgning til politiet.' },
  { q: 'Stævner og events', a: 'Se kalenderen for kommende arrangementer, eller kontakt os for særarrangementer.' },
];
---

<BaseLayout title="Kontakt" description="Kontakt Holmegaard Skytteforening på kontakt@hskf.dk. Vi besvarer spørgsmål om indmeldelse, SKV, firmaevents og træningstider.">

  <div class="bg-gradient-to-b from-gray-50 to-white dark:from-gray-900 dark:to-gray-950 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="max-w-2xl mb-12">
        <h1 class="section-title">Kontakt</h1>
        <p class="section-subtitle">Har du spørgsmål eller vil du høre mere om HSKF? Vi hører gerne fra dig.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- Contact info -->
        <div class="space-y-6">
          <div class="card border border-gray-100 dark:border-gray-800 p-6">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #ffe4e6;">
                <svg class="w-5 h-5" style="color: var(--color-primary-500);" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white mb-1">Email</h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm mb-2">Skriv til os – vi svarer typisk inden for 1-2 hverdage.</p>
                <a href="mailto:kontakt@hskf.dk" class="font-semibold transition-colors" style="color: var(--color-primary-500);">kontakt@hskf.dk</a>
              </div>
            </div>
          </div>

          <div class="card border border-gray-100 dark:border-gray-800 p-6">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #ffe4e6;">
                <svg class="w-5 h-5" style="color: var(--color-primary-500);" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white mb-1">Telefon</h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm mb-2">Ring til os for hurtige spørgsmål.</p>
                <a href="tel:+4523215049" class="font-semibold transition-colors" style="color: var(--color-primary-500);">+45 23 21 50 49</a>
              </div>
            </div>
          </div>

          <div class="card border border-gray-100 dark:border-gray-800 p-6">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #ffedd5;">
                <svg class="w-5 h-5 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white mb-1">Udendørs Toksværd</h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm">Udendørs – åben i sommerhalvåret</p>
                <a href="https://maps.google.com/?q=Lundebakkevej+18C,+4684+Holmegaard" target="_blank" rel="noopener noreferrer" class="font-medium mt-1 text-sm hover:underline" style="color: var(--color-primary-500);">Lundebakkevej 18C, 4684 Holmegaard</a>
              </div>
            </div>
          </div>

          <div class="card border border-gray-100 dark:border-gray-800 p-6">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #ccfbf1;">
                <svg class="w-5 h-5 text-teal-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white mb-1">Indendørs Fensmark</h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm">Indendørs – åbent i vinterhalvåret</p>
                <a href="https://maps.google.com/?q=Villavej+2,+4684+Holmegaard" target="_blank" rel="noopener noreferrer" class="font-medium mt-1 text-sm hover:underline" style="color: var(--color-primary-500);">Villavej 2, 4684 Holmegaard</a>
              </div>
            </div>
          </div>

          <div class="p-5 rounded-xl border bg-rose-50 dark:bg-rose-950/30 border-rose-200 dark:border-rose-900">
            <h3 class="font-semibold mb-2 text-rose-900 dark:text-rose-200">Book et arrangement</h3>
            <p class="text-sm leading-relaxed mb-3 text-rose-800 dark:text-rose-300">Planlægger I en firmatur, polterabend eller andet arrangement? Vi tilbyder skydeoplevelser for grupper.</p>
            <a href="/book-arrangement" class="btn-primary text-sm">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              Book en skydeoplevelse
            </a>
          </div>
        </div>

        <!-- Right col: FAQ -->
        <div class="space-y-6">
          <div class="card border border-gray-100 dark:border-gray-800 p-6">
            <h3 class="font-bold text-gray-900 dark:text-white mb-4">Hvad kan vi hjælpe med?</h3>
            <div class="space-y-4">
              {faq.map((item) => (
                <div class="border-b border-gray-100 dark:border-gray-800 pb-4 last:border-0 last:pb-0">
                  <div class="font-semibold text-gray-900 dark:text-white text-sm mb-1">{item.q}</div>
                  <div class="text-sm text-gray-600 dark:text-gray-400">{item.a}</div>
                </div>
              ))}
            </div>
          </div>

          <div class="card border border-gray-100 dark:border-gray-800 p-6">
            <h3 class="font-bold text-gray-900 dark:text-white mb-4">Træningstider</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Træning er typisk torsdage. Se den fulde oversigt:</p>
            <a href="/traeningstider" class="btn-outline text-sm">Se træningstider</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
