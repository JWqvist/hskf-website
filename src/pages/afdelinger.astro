---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Afdelinger" description="HSKF råder over to skydebaner – en udendørs bane i Toksværd og en indendørs bane i Holmegaard. Pistol og riffel for alle niveauer.">

  <div class="bg-gradient-to-b from-gray-50 to-white dark:from-gray-900 dark:to-gray-950 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="max-w-2xl mb-8">
        <h1 class="section-title">Vores afdelinger</h1>
        <p class="section-subtitle">HSKF råder over to velfungerende skydeanlæg, der tilbyder optimale betingelser for alle discipliner og niveauer.</p>
      </div>

      <!-- Anchor navigation -->
      <div class="flex flex-wrap gap-3 mb-12">
        <a href="#toksvaerd" class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold transition-colors" style="background-color: #fed7aa; color: #9a3412;">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Udendørs Toksværd
        </a>
        <a href="#holmegaard" class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold transition-colors" style="background-color: #ccfbf1; color: #115e59;">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          Indendørs Fensmark
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16">

        <!-- Toksvær -->
        <div id="toksvaerd" class="card border border-gray-100 dark:border-gray-800 overflow-hidden flex flex-col">
          <div class="h-48 relative overflow-hidden">
            <div class="absolute inset-0" style="background-image: url('/images/IMG_3243-scaled.jpg'); background-size: cover; background-position: center;"></div>
            <div class="absolute inset-0" style="background: linear-gradient(to bottom right, rgba(249,115,22,0.65), rgba(217,119,6,0.55));"></div>
            <div class="absolute top-4 left-4">
              <span class="inline-block px-3 py-1 text-white text-xs font-bold rounded-full uppercase tracking-wider" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(4px);">Udendørs</span>
            </div>

          </div>
          <div class="p-6 flex flex-col flex-1">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">Udendørs Toksværd</h2>

            <p class="font-medium text-sm mb-4" style="color: var(--color-primary-500);">Riffel · Pistol</p>
            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-5 flex-grow">
              Udendørs Toksværd er vores smukke udendørs anlæg beliggende i naturskønne omgivelser. Banen er ideel til riffel- og pistoletræning under åben himmel. Primær bane i sommerhalvåret.
            </p>
            <ul class="space-y-2 mb-6">
              <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary-500);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Distancer: 25m, 50m
              </li>
              <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary-500);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Discipliner: Riffel, Pistol
              </li>
              <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary-500);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Primær bane i sommerhalvåret
              </li>
              <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary-500);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                Kørestolsvenlig niveaufri adgang
              </li>
            </ul>
            <div class="flex items-start gap-2 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
              <svg class="w-4 h-4 text-gray-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <div>
                <a href="https://maps.google.com/?q=Lundebakkevej+18C,+4684+Holmegaard" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold hover:underline" style="color: var(--color-primary-500);">Lundebakkevej 18C</a>
                <p class="text-sm text-gray-500 dark:text-gray-400">4684 Holmegaard</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Holmegaard -->
        <div id="holmegaard" class="card border border-gray-100 dark:border-gray-800 overflow-hidden flex flex-col">
          <div class="h-48 relative overflow-hidden">
            <div class="absolute inset-0" style="background-image: url('/images/IMG_3237-1-scaled.jpg'); background-size: cover; background-position: center;"></div>
            <div class="absolute inset-0" style="background: linear-gradient(to bottom right, rgba(20,184,166,0.65), rgba(8,145,178,0.55));"></div>
            <div class="absolute top-4 left-4">
              <span class="inline-block px-3 py-1 text-white text-xs font-bold rounded-full uppercase tracking-wider" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(4px);">Indendørs</span>
            </div>
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">Indendørs Fensmark</h2>
            <p class="font-medium text-sm mb-4" style="color: var(--color-primary-500);">Riffel · Pistol</p>
            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-5 flex-grow">
              Vores indendørs skydecenter i Holmegaard huser faciliteter til riffel- og pistolskydning. Perfekte forhold uanset vejret – ideelt for den seriøse skytte såvel som begynderen. Primær bane i vinterhalvåret.
            </p>
            <ul class="space-y-2 mb-6">
              <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary-500);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Distance: 15m
              </li>
              <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary-500);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Discipliner: Riffel, Pistol
              </li>
              <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary-500);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Primær bane i vinterhalvåret
              </li>
              <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
                <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary-500);" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Banen er i kælder – ikke tilgængelig for kørestolsbrugere
              </li>
            </ul>
            <div class="flex items-start gap-2 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
              <svg class="w-4 h-4 text-gray-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <div>
                <a href="https://maps.google.com/?q=Villavej+2,+4684+Holmegaard" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold hover:underline" style="color: var(--color-primary-500);">Villavej 2</a>
                <p class="text-sm text-gray-500 dark:text-gray-400">4684 Holmegaard</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Map section -->
      <div class="mb-4">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Find os</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-6">Begge baner ligger i Holmegaard, Næstved Kommune.</p>
      </div>

      <div id="map" class="w-full rounded-xl overflow-hidden shadow-lg border border-gray-200 dark:border-gray-700 z-10" style="height: 24rem;"></div>

      <div class="mt-4 flex flex-wrap gap-4">
        <div class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
          <div class="w-4 h-4 rounded-full border-2 border-white shadow" style="background-color: #f97316;"></div>
          <span>Udendørs Toksværd</span>
        </div>
        <div class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
          <div class="w-4 h-4 rounded-full border-2 border-white shadow" style="background-color: #14b8a6;"></div>
          <span>Indendørs Fensmark</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Leaflet -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      const map = L.map('map').setView([55.263, 11.840], 12);

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
        maxZoom: 18,
      }).addTo(map);

      const orangeIcon = L.divIcon({
        html: '<div style="background:#f97316;width:26px;height:26px;border-radius:50%;border:3px solid white;box-shadow:0 2px 8px rgba(0,0,0,0.3)"></div>',
        className: '',
        iconSize: [26, 26],
        iconAnchor: [13, 13],
        popupAnchor: [0, -14],
      });

      const tealIcon = L.divIcon({
        html: '<div style="background:#14b8a6;width:26px;height:26px;border-radius:50%;border:3px solid white;box-shadow:0 2px 8px rgba(0,0,0,0.3)"></div>',
        className: '',
        iconSize: [26, 26],
        iconAnchor: [13, 13],
        popupAnchor: [0, -14],
      });

      L.marker([55.2463, 11.8709], { icon: orangeIcon })
        .addTo(map)
        .bindPopup('<strong>Udendørs Toksværd</strong><br><a href="https://maps.google.com/?q=Lundebakkevej+18C,+4684+Holmegaard" target="_blank">Lundebakkevej 18C, 4684 Holmegaard</a><br><em>Udendørs · Riffel &amp; Pistol</em>');

      L.marker([55.2788, 11.8117], { icon: tealIcon })
        .addTo(map)
        .bindPopup('<strong>Indendørs Fensmark</strong><br><a href="https://maps.google.com/?q=Villavej+2,+4684+Holmegaard" target="_blank">Villavej 2, 4684 Holmegaard</a><br><em>Indendørs · Riffel &amp; Pistol</em>');
    });
  </script>

</BaseLayout>
